# Environment variables for the Purple Agent
# Copy this to .env and fill in your API keys

# Primary LLM provider (pick one)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Agent configuration
AGENT_LLM=openai/gpt-4.1

# Google Vertex AI (if using Gemini via Vertex)
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
